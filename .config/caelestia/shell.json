        "dangerous": false,
        "description": "Suspend then hibernate",
        "enabled": true,
        "icon": "bedtime",
        "name": "Sleep"
      },
      {
        "command": [
          "caelestia",
          "shell",
          "controlCenter",
          "open"
        ],
        "dangerous": false,
        "description": "Configure the shell",
        "enabled": true,
        "icon": "settings",
        "name": "Settings"
