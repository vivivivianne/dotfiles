      {
        "command": [
          "setMode",
          "dark"
        ],
        "dangerous": false,
        "description": "Change the scheme to dark mode",
        "enabled": true,
        "icon": "dark_mode",
        "name": "Dark"
      },
      {
        "command": [
          "systemctl",
          "poweroff"
